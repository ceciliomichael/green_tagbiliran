# ==========================================
# Green Tagbilaran Environment Variables
# ==========================================
# This is an example of the required environment variables.
# Copy this file to `.env` and fill in your actual credentials.
# Note: Do not commit the `.env` file to version control.

# ------------------------------------------
# Google Gemini AI Configuration
# ------------------------------------------
# The API endpoint for the Gemini model you are using.
# Since the code uses OpenAI's request format, we use Google's OpenAI-compatible endpoint:
GOOGLE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# Your Google AI Studio API key. Get it from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# The specific Gemini model you wish to use (Optional).
# Default: gemini-flash-lite-latest
GOOGLE_MODEL=gemma-4-31b-it

# ------------------------------------------
# Supabase Configuration
# ------------------------------------------
# Your project's unique Supabase URL.
# Found in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=

# Your project's public anonymous key.
# Found in Supabase Dashboard -> Project Settings -> API (anon / public)
SUPABASE_ANON_KEY=
